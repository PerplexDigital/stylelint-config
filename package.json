        "@stylistic/stylelint-plugin": "^3.1.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.2.1",
        "husky": "^9.1.7",
        "lint-staged": "^15.2.10",
        "prettier": "^3.4.2",
        "stylelint": "^16.11.0",
        "stylelint-config-recommended-vue": "^1.5.0",
