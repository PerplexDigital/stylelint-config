    "type": "module",
    "exports": {
        ".": "./index.js",
        "./declarations": "./declarations.js",
        "./groups": "./groups.js"
    },
    "main": "index.js",
    "files": [
        "index.js",
        "declarations.js",
        "groups.js"
    ],
    "scripts": {
