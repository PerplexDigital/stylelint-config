{
    "name": "@perplex-digital/stylelint-config",
    "version": "2.0.0",
    "description": "Box model-based property sort order for Stylelint.",
    "keywords": [
        "logical properties",
        "properties-order",
        "property order",
        "box model",
        "stylelint",
        "stylelint-config",
        "stylelint-order"
    ],
    "homepage": "https://github.com/PerplexDigital/stylelint-config",
    "bugs": "https://github.com/PerplexDigital/stylelint-config/issues",
    "repository": "PerplexDigital/stylelint-config",
    "license": "ISC",
    "author": "Tobias Boekwijt (https://perplex.nl/en/about-perplex/the-perplexers#tobias-boekwijt)",
    "type": "module",
    "exports": {
        ".": "./index.js",
        "./declarations": "./declarations.js",
        "./groups": "./groups.js"
    },
    "main": "index.js",
    "files": [
        "index.js",
        "declarations.js",
        "groups.js"
    ],
    "scripts": {
        "changeset": "changeset add",
        "lint": "eslint '**/*.js'",
        "prepare": "husky",
        "release": "changeset publish",
        "test": "node --test"
    },
    "lint-staged": {
        "*.js": [
            "eslint --fix",
            "prettier --write"
        ],
        "package.json": "prettier --write"
    },
    "dependencies": {
        "@stylistic/stylelint-plugin": "^3.1.2",
        "stylelint-config-recommended-vue": "^1.6.0",
        "stylelint-config-standard": "^36.0.1",
        "stylelint-high-performance-animation": "^1.11.0",
        "stylelint-order": "^6.0.4",
        "stylelint-use-logical-spec": "^5.0.1"
    },
    "devDependencies": {
        "@changesets/cli": "^2.28.1",
        "@commitlint/cli": "^19.8.0",
        "@commitlint/config-conventional": "^19.8.0",
        "@nuxt/eslint-config": "^1.2.0",
        "@zazen/changesets-changelog": "^2.0.3",
        "eslint": "^9.23.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.0",
        "prettier": "^3.5.3",
        "stylelint": "^16.16.0",
        "typescript": "^5.8.2"
    },
    "peerDependencies": {
        "stylelint": ">=16"
    }
}
